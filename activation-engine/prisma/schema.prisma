generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

// ─── Enums ───────────────────────────────────────────────

enum PoolStatus {
  DRAFT
  APPROVED
  ACTIVE
  CLOSED
}

enum PoolMemberSide {
  INVESTOR
  FOUNDER
}

enum PoolMemberStatus {
  PENDING
  ACTIVE
  RESPONDED
  COMPLETED
  REMOVED
}

enum PoolPairStatus {
  PENDING
  INVESTOR_YES
  FOUNDER_YES
  MUTUAL_YES
  INVESTOR_NO
  FOUNDER_NO
  NO_MATCH
  INTRO_SENT
  COMPLETED
}

enum EmailSequenceStep {
  A1_MATCH_LIST
  A1_FU_FOLLOWUP
  A2_CONFIRMATION
  A3_INTRO
  A4_FEEDBACK
  B1_MATCH_LIST
  B1_FU_FOLLOWUP
  B2_CONFIRMATION
  B3_INTRO
  B4_FEEDBACK
}

enum ActivationStatus {
  UNACTIVATED
  IN_POOL
  ACTIVATED
  STRONG_ACTIVATED
  AT_RISK
}

enum InvestorTier {
  HOT
  WARM
  GAP_FILL
}

enum EventType {
  POOL_CREATED
  POOL_APPROVED
  POOL_ACTIVATED
  POOL_CLOSED
  EMAIL_SENT
  EMAIL_OPENED
  EMAIL_REPLIED
  RESPONSE_PARSED
  INTRO_TRIGGERED
  INTRO_SENT
  USER_CLASSIFIED
  MANUAL_OVERRIDE
}

enum NudgeType {
  POST_POOL_REMINDER
  ACTIVATION_PROMPT
  RE_ENGAGEMENT
  FEEDBACK_REQUEST
}

// ─── Models ──────────────────────────────────────────────

model Pool {
  id        String     @id @default(cuid())
  industry  String
  status    PoolStatus @default(DRAFT)

  // Size constraints
  minInvestors Int @default(3)
  maxInvestors Int @default(6)
  minFounders  Int @default(3)
  maxFounders  Int @default(6)

  // SLA
  slaHours Int @default(48)

  // Ownership
  ownerId   String?
  ownerName String?

  // Test mode
  isTestPool Boolean @default(false)

  // Approval
  approvedBy String?
  approvedAt DateTime?

  // Activation
  activatedAt DateTime?
  closedAt    DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  members PoolMember[]
  pairs   PoolPair[]
  events  EventLedger[]
}

model PoolMember {
  id     String         @id @default(cuid())
  poolId String
  pool   Pool           @relation(fields: [poolId], references: [id], onDelete: Cascade)
  userId String         // References Syrena User.id (plain string, no FK)
  side   PoolMemberSide
  status PoolMemberStatus @default(PENDING)

  // Investor-specific
  investorTier InvestorTier?

  // Cached from Syrena at pool creation
  displayName String?
  email       String?

  // Engagement score at time of pool generation
  engagementScore Float @default(0)

  // Three-stage tracking
  stage               Int       @default(0) // 0=Not started, 1=Presented, 2=Selected, 3=Feedback
  matchesPresentedIds Json?     // String[] — userIds of matches shown
  selectedMatchIds    Json?     // String[] — userIds this member selected
  respondedAt         DateTime?
  stageCompletedAt    DateTime? // All 3 stages done = ACTIVATED

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([poolId, userId])
  @@index([userId])
}

model PoolPair {
  id         String         @id @default(cuid())
  poolId     String
  pool       Pool           @relation(fields: [poolId], references: [id], onDelete: Cascade)
  investorId String         // References Syrena User.id
  founderId  String         // References Syrena User.id
  score      Float          @default(0)
  rank       Int            @default(0)
  status     PoolPairStatus @default(PENDING)

  // Denormalized for quick display
  investorName  String?
  investorEmail String?
  founderName   String?
  founderEmail  String?

  // Presentation tracking
  presentedToInvestor Boolean @default(false)
  presentedToFounder  Boolean @default(false)

  // Stage 2: Selection
  investorSelected Boolean @default(false)
  founderSelected  Boolean @default(false)

  // Cross-match outcome
  crossMatchOutcome String? // "MUTUAL_YES" | "INVESTOR_ONLY" | "FOUNDER_ONLY" | "NO_MATCH" | "PENDING"

  // Stage 3: Feedback
  investorFeedback         String?
  investorFeedbackPositive Boolean?
  founderFeedback          String?
  founderFeedbackPositive  Boolean?
  feedbackDeliveredAt      DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  emails              OutreachEmail[]
  introduction        Introduction?
  matchScore          MatchScore?
  personalizationLines PersonalizationLine[]

  @@unique([poolId, investorId, founderId])
  @@index([investorId])
  @@index([founderId])
}

model OutreachEmail {
  id         String            @id @default(cuid())
  poolPairId String
  poolPair   PoolPair          @relation(fields: [poolPairId], references: [id], onDelete: Cascade)
  side       PoolMemberSide
  step       EmailSequenceStep

  resendEmailId String?
  sentAt        DateTime?
  deliveredAt   DateTime?
  openedAt      DateTime?
  clickedAt     DateTime?
  repliedAt     DateTime?
  bouncedAt     DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  response ResponseRecord?

  @@index([poolPairId])
  @@index([resendEmailId])
}

model ResponseRecord {
  id              String        @id @default(cuid())
  outreachEmailId String        @unique
  outreachEmail   OutreachEmail @relation(fields: [outreachEmailId], references: [id], onDelete: Cascade)

  rawResponse    String?
  parsedChoices  Json?   // e.g. { "selectedFounders": ["id1", "id3"] }
  confidence     Float   @default(0)

  // Manual override
  overriddenBy   String?
  overriddenAt   DateTime?
  overrideReason String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Introduction {
  id         String   @id @default(cuid())
  poolPairId String   @unique
  poolPair   PoolPair @relation(fields: [poolPairId], references: [id], onDelete: Cascade)

  status          String @default("PENDING") // PENDING, SENT, ACCEPTED, DECLINED
  introEmailBody  String?
  resendEmailId   String?

  sentAt      DateTime?
  acceptedAt  DateTime?
  declinedAt  DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model UserActivationStatus {
  id     String           @id @default(cuid())
  userId String           @unique // References Syrena User.id
  side   PoolMemberSide
  status ActivationStatus @default(UNACTIVATED)

  poolCount    Int @default(0)
  introCount   Int @default(0)
  responseRate Float @default(0)

  activatedAt       DateTime?
  strongActivatedAt DateTime?
  lastPoolAt        DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([status])
  @@index([side])
}

model EventLedger {
  id      String    @id @default(cuid())
  type    EventType
  actorId String?   // Who triggered this (operator or system)
  poolId  String?
  pool    Pool?     @relation(fields: [poolId], references: [id], onDelete: SetNull)
  payload Json?     // Flexible event data

  createdAt DateTime @default(now())

  @@index([type])
  @@index([poolId])
  @@index([createdAt])
}

model ConversionNudge {
  id        String    @id @default(cuid())
  userId    String    // References Syrena User.id
  nudgeType NudgeType
  sentAt    DateTime  @default(now())

  resendEmailId String?
  convertedAt   DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId])
}

model MatchScore {
  id         String   @id @default(cuid())
  poolPairId String   @unique
  poolPair   PoolPair @relation(fields: [poolPairId], references: [id], onDelete: Cascade)
  investorId String
  founderId  String

  totalScore        Float @default(0)
  industryScore     Float @default(0)
  locationScore     Float @default(0)
  stageScore        Float @default(0)
  chequeSizeScore   Float @default(0)
  engagementScore   Float @default(0)

  featureVector Json? // Raw feature data for ML

  // Outcome tracking
  outcome       String?   // "INTRO_SENT" | "MUTUAL_YES" | "ONE_SIDED" | "NO_MATCH"
  outcomeReason String?
  outcomeAt     DateTime?

  createdAt DateTime @default(now())

  @@index([investorId])
  @@index([founderId])
}

// ─── Personalization ────────────────────────────────────

model PersonalizationLine {
  id         String   @id @default(cuid())
  poolPairId String
  poolPair   PoolPair @relation(fields: [poolPairId], references: [id], onDelete: Cascade)

  side     PoolMemberSide // Which side sees this line
  line     String         // "Relevant because they invest in early-stage AI..."
  approved Boolean @default(false)

  generatedAt DateTime  @default(now())
  approvedAt  DateTime?
  approvedBy  String?

  @@index([poolPairId])
}

// ─── New Joiners ────────────────────────────────────────

model NewJoinerMatch {
  id          String         @id @default(cuid())
  userId      String         // The new joiner (Syrena User.id)
  side        PoolMemberSide // INVESTOR or FOUNDER
  matchUserId String         // The matched user (Syrena User.id)

  // Denormalized for display
  userName   String?
  userEmail  String?
  matchName  String?
  matchEmail String?

  score       Float   @default(0)
  whyRelevant String? // LLM-generated line
  approved    Boolean @default(false) // Operator approved

  // Stage tracking (simplified: presented → selected → done)
  stage            Int      @default(0) // 0=Draft, 1=Presented, 2=Selected, 3=Done
  selected         Boolean  @default(false)
  feedback         String?
  feedbackPositive Boolean?

  // Email tracking
  emailSentAt DateTime?
  isTestMode  Boolean @default(false)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId])
  @@index([matchUserId])
}

// ─── Activation Workspace (Pipeline Tracker) ────────────

enum ActivationSide {
  INVESTOR
  FOUNDER
}

enum ActivationStage {
  NEW                    // Just added to pipeline
  S1_MATCHES_SENT        // Stage 1: Match list emailed to user
  S2_USER_RESPONDED      // Stage 2: User replied with selection
  S3_COUNTERPARTY_ASKED  // Stage 3: Counterparty contacted
  S3_FEEDBACK_RECEIVED   // Stage 3: Counterparty responded
  ACTIVATED              // All stages complete — intro made or feedback delivered
  STALLED                // SLA expired or no response
  DECLINED               // User opted out
}

model ActivationRecord {
  id              String          @id @default(cuid())
  syrenaUserId    String          // References Syrena User.id
  side            ActivationSide

  // Denormalized from Syrena for fast display (no extra SQL per row)
  name            String
  email           String
  company         String?         // Founder company name / Investor firm
  industry        String          // Primary industry
  fundingStage    String?         // Founder: current stage / Investor: stages they invest

  // Pipeline tracking
  stage           ActivationStage @default(NEW)
  owner           String?         // Team member who owns this record

  // Stage 1: Matches sent
  matchesSentAt   DateTime?
  matchesSentBy   String?         // Who sent the email

  // Stage 2: User responded
  respondedAt     DateTime?
  selectedMatchId String?         // Which match they picked

  // Stage 3: Counterparty
  counterpartyAskedAt     DateTime?
  counterpartyRespondedAt DateTime?
  outcome                 String?  // "intro_made" | "declined" | "no_response"

  // Activation
  activatedAt     DateTime?

  // Notes
  notes           String?

  // SLA tracking
  slaDeadline     DateTime?

  // Link to pool system (optional)
  poolId          String?

  createdAt       DateTime        @default(now())
  updatedAt       DateTime        @updatedAt

  matches         ActivationMatch[]
  activityLogs    ActivityLog[]

  @@unique([syrenaUserId])
  @@index([stage])
  @@index([side])
  @@index([owner])
  @@index([industry])
}

model ActivationMatch {
  id                  String           @id @default(cuid())
  activationRecordId  String
  activationRecord    ActivationRecord @relation(fields: [activationRecordId], references: [id], onDelete: Cascade)

  matchSyrenaUserId   String
  matchSide           ActivationSide

  // Denormalized
  matchName           String
  matchEmail          String
  matchCompany        String?
  matchIndustry       String?

  // Personalization
  whyRelevant         String?

  // Selection & outcome
  selected            Boolean          @default(false)
  counterpartyResponse String?         // "interested" | "declined" | "no_response"
  introSent           Boolean          @default(false)
  introSentAt         DateTime?

  // Email tracking
  emailSentToMatch    Boolean          @default(false)
  emailSentToMatchAt  DateTime?

  // Feedback
  feedback            String?
  feedbackDelivered   Boolean          @default(false)
  feedbackDeliveredAt DateTime?

  score               Float            @default(0)

  createdAt           DateTime         @default(now())
  updatedAt           DateTime         @updatedAt

  @@index([activationRecordId])
  @@index([matchSyrenaUserId])
}

// ─── Activity Logs (Audit Trail) ───────────────────────

model ActivityLog {
  id                  String           @id @default(cuid())
  activationRecordId  String
  activationRecord    ActivationRecord @relation(fields: [activationRecordId], references: [id], onDelete: Cascade)

  action              String   // "stage_changed", "owner_changed", "notes_updated", "match_selected", "intro_sent", "feedback_delivered", "record_created", etc.
  actor               String?  // Team member name who performed the action
  detail              String?  // Human-readable description e.g. "Stage changed from New to Matches Sent"
  meta                Json?    // Structured data e.g. { from: "NEW", to: "S1_MATCHES_SENT" }

  createdAt           DateTime @default(now())

  @@index([activationRecordId])
  @@index([createdAt])
}

// ─── Email Templates ────────────────────────────────────

model EmailTemplate {
  id          String          @id @default(cuid())
  slug        String          @unique
  name        String
  subject     String
  body        String
  side        ActivationSide?
  description String?

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}
